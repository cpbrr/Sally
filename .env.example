# Sally configuration — copied into your Sally data folder as `.env` by setup.
# The API key is stored in plain text by design; anyone who can read or copy
# this folder can obtain the key. Do not commit a real key.

GEMINI_API_KEY=
# Preview model names and free-tier access change; both are configurable.
SALLY_LIVE_MODEL=gemini-3.5-live-translate-preview
SALLY_CLEANUP_MODEL=gemini-3.1-flash-lite
SALLY_TARGET_LANGUAGE=Vietnamese
# Interface language: en | vi
SALLY_UI_LANGUAGE=en
# Keep the floating window above meeting apps by default: on | off
# (default off; the pin button in the title bar enables it per window)
SALLY_ALWAYS_ON_TOP=off
# Live API version: v1alpha | v1beta. Preview models usually need v1alpha;
# Sally switches automatically if the configured one keeps rejecting setup.
SALLY_LIVE_API_VERSION=v1alpha
# Device names as listed in Settings; empty = system default
SALLY_MIC_DEVICE=
SALLY_SYSTEM_DEVICE=
# Read the translated voice aloud for passages not already in the target
# language (e.g. target Vietnamese: English/Japanese speech is read out,
# Vietnamese speech is not). Use headphones to avoid feedback. on | off
SALLY_READOUT=off
# Split "Meeting" lines when a different remote voice takes over. The
# segmentation model (~6 MB) downloads on first meeting. on | off
SALLY_SPEAKER_SPLIT=on
# Override the segmentation model download URL (air-gapped setups can
# drop models/segmentation_pyannote3.onnx into the data folder instead).
SALLY_SEGMENTATION_MODEL_URL=
